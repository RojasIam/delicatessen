# Public app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only (never expose in browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Vercel (deploy automatico) ---
# 1. Conecta el repo: https://vercel.com/new → Import Git Repository → este proyecto.
# 2. Framework: Next.js (Vercel lo detecta solo al ver package.json).
# 3. Settings → Environment Variables: las mismas claves que arriba en Production
#    (y Preview si quieres Supabase en ramas).
# 4. NEXT_PUBLIC_SITE_URL en producción: https://TU-DOMINIO.vercel.app o dominio custom.
# 5. Cada push al branch enlazado (p. ej. main) ejecuta npm run build y despliega.

